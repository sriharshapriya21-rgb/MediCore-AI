# MediCore AI - Environment Variables Example
# Port 3000 is externally bound and pre-configured for Cloud Run containers.

# Google Gemini API key for smart clinical assessments
GEMINI_API_KEY=

# MongoDB Atlas Database URI connection string (optional - falls back to robust local memory store if blank)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/medicore_db

# JSON Web Token secret key for signing secure practitioner and patient sessions
JWT_SECRET=MEDICORE_JWT_SUPER_SECRET_KEY_SPECIAL_PHRASE
